# .env.example — copy to `.env` and customize for your environment
# Usage: cp .env.example .env && docker compose up -d
#
# This file lists environment variables consumed by `docker-compose.yml` and
# related provisioning. Each variable includes a sensible default where
# appropriate; remove the comment and set your custom value in `.env`.

# General
# (No project-wide defaults required; set Docker project name via CLI if needed)

# -------------------- Prometheus --------------------
# Port on the host that maps to Prometheus web UI (container port 9090)
PROMETHEUS_PORT=9090
# How long to retain TSDB data (e.g. 15d, 90d, 1y). Matches Prometheus CLI format.
PROMETHEUS_RETENTION_TIME=30d
# Full URL used by Grafana to reach Prometheus. Example: http://prometheus:9090
# If set, `PROMETHEUS_URL` will be used by Grafana provisioning.
PROMETHEUS_URL=http://prometheus:9090

# -------------------- Grafana --------------------
# Port on the host that maps to Grafana web UI (container port 3000)
GRAFANA_PORT=3000
# Grafana admin user/password — override in production!
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Allow users to sign up via Grafana UI (true/false)
GRAFANA_ALLOW_SIGN_UP=false
# Dashboard refresh interval defaults (Grafana duration format)
GRAFANA_MIN_REFRESH_INTERVAL=5s
GRAFANA_DEFAULT_REFRESH_INTERVAL=5s

# -------------------- Exporters / Collectors --------------------
# Node Exporter port (container 9100)
NODE_EXPORTER_PORT=9100
# cAdvisor port mapping (container 8080)
CADVISOR_PORT=8081

# -------------------- Example App (Dozzle) --------------------
# Doozle (container log viewer) port (container 8080)
DOOZLE_PORT=8082
# Environment for example app
DOOZLE_ENV=production

# -------------------- Optional / Advanced --------------------
# SMTP / Alerting (optional) — examples for Grafana alerting / notifications
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=alerts@example.com

