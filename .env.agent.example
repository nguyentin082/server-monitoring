# .env.agent.example — copy sang `.env` trên mỗi remote server và tùy chỉnh
# Usage: cp .env.agent.example .env && docker compose -f docker-compose.agent.yml up -d

# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  BẮT BUỘC PHẢI ĐỔI
# ─────────────────────────────────────────────────────────────────────────────

# IP hoặc domain của Monitor Server (nơi đang chạy Loki)
LOKI_URL=http://<MONITOR_SERVER_IP>:3100

# Tên hostname để phân biệt server này trong Grafana (ví dụ: web-server-01, db-server)
SERVER_HOSTNAME=my-server-name

# ─────────────────────────────────────────────────────────────────────────────
# Tuỳ chọn (có thể giữ mặc định)
# ─────────────────────────────────────────────────────────────────────────────

# Port cho Node Exporter (Prometheus sẽ scrape port này)
NODE_EXPORTER_PORT=9100

# Phiên bản Promtail (nên khớp với LOKI_VERSION trên Monitor Server)
PROMTAIL_VERSION=3.5.0
